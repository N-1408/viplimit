# 🗄️ Database Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=viplimit
DB_USER=postgres
DB_PASSWORD=your_password_here

# 🔒 JWT Secret Key
JWT_SECRET=your_super_secret_jwt_key_change_this

# 🌐 Server Port
PORT=5000

# 🔑 Default Owner Password (for initial setup)
DEFAULT_OWNER_PASSWORD=admin123
