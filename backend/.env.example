# 🗄️ Database Connection (LOCAL — faqat development uchun)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=viplimit
DB_USER=postgres
DB_PASSWORD=your_password

# 🗄️ Database Connection (PRODUCTION — Supabase)
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# 🔒 JWT Secret Key
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# 🌐 Server Port
PORT=5000

# 🤖 Telegram Bot Token (BotFather dan olinadi)
# BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# 🔒 Super Admin Telegram ID
# SUPER_ADMIN_TG_ID=123456789

# 🌐 WebApp URL (Render domain)
# WEBAPP_URL=https://viplimit.onrender.com

# 🔑 Default Owner Password (for initial setup)
DEFAULT_OWNER_PASSWORD=admin123
